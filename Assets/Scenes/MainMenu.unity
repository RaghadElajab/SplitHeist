--- !u!114 &1235858366
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1235858362}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 13a0501453e2c8d4aa04c0b7a156a3d1, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  smallSize: 15
  mediumSize: 20
  largeSize: 25
  defaultFont: {fileID: 11400000, guid: 2e498d1c8094910479dc3e1b768306a4, type: 2}
  arabicFont: {fileID: 11400000, guid: c5e7f7ab256412e4ebf3688361a9cda9, type: 2}
  texts:
  - "<align=center><color=#FDF67DFF>\r\nSplit Heist is a two-player cooperative puzzle
    platformer set inside a high-security bank. Each player explores separate but
    connected areas, so success depends on teamwork, timing, and communication. Work
    together to solve puzzles, avoid detection, and create a safe route to the vault.\r\n</color></align>\r\n\r\n<size=130%><b><color=#FFD54A>Your
    Objective</color></b></size>  \r\n<color=#FDF67DFF>\u2022 Reach the vault without
    being detected  \r\n\u2022 Coordinate actions to help your partner progress 
    \r\n\u2022 Work together to clear each level</color>\r\n\r\n<size=130%><b><color=#FFD54A>What
    to Do</color></b></size>  \r\n<color=#FDF67DFF>\u2022 Activate switches to control
    parts of the level  \r\n\u2022 Time moving platforms to reach new areas  \r\n\u2022
    Push crates to access higher or blocked paths  \r\n\u2022 Avoid or disable security
    cameras  \r\n\u2022 Navigate laser systems without triggering alarms</color>\r\n\r\n<size=130%><b><color=#FFD54A>Controls</color></b></size> 
    \r\n<color=#FDF67DFF>\u2022 Player 1: <b>W A S D</b>  \r\n\u2022 Player 2: <b>Arrow
    Keys</b>  \r\n\u2022 Use interaction key to activate switches or objects  \r\n\u2022
    Communicate to coordinate timing and movement</color>\r\n\r\n<size=130%><b><color=#FFD54A>Scoring
    and Progression</color></b></size>  \r\n<color=#FDF67DFF>\u2022 Levels are timed
    \u2014 faster completion = higher score  \r\n\u2022 Collect optional items to
    boost your score  \r\n\u2022 Earn up to <b>3 stars</b> per level  \r\n\u2022
    Get at least <b>2 stars</b> to unlock the next level</color>\r\n\r\n<size=130%><b><color=#FFD54A>If
    You Get Stuck</color></b></size>  \r\n<color=#FDF67DFF>\u2022 Use the <b>Hint
    System</b> for guidance  \r\n\u2022 Hints point you toward the next step in a
    puzzle  \r\n\u2022 Check both screens and communicate first  \r\n\u2022 Use hints
    if you're unsure what to do next</color>"
  - "<align=center><color=#FDF67DFF>\r\n\u0633\u0628\u0644\u064A\u062A \u0647\u0627\u064A\u0633\u062A
    \u0647\u064A \u0644\u0639\u0628\u0629 \u0645\u0646\u0635\u0627\u062A \u0648\u0623\u0644\u063A\u0627\u0632
    \u062A\u0639\u0627\u0648\u0646\u064A\u0629 \u0644\u0644\u0627\u0639\u0628\u064A\u0646
    \u062A\u062F\u0648\u0631 \u0623\u062D\u062F\u0627\u062B\u0647\u0627 \u062F\u0627\u062E\u0644
    \u0628\u0646\u0643 \u0639\u0627\u0644\u064A \u0627\u0644\u062D\u0631\u0627\u0633\u0629.
    \u064A\u0633\u062A\u0643\u0634\u0641 \u0643\u0644 \u0644\u0627\u0639\u0628 \u0645\u0646\u0627\u0637\u0642
    \u0645\u0646\u0641\u0635\u0644\u0629 \u0644\u0643\u0646\u0647\u0627 \u0645\u062A\u0631\u0627\u0628\u0637\u0629\u060C
    \u0644\u0630\u0644\u0643 \u064A\u0639\u062A\u0645\u062F \u0627\u0644\u0646\u062C\u0627\u062D
    \u0639\u0644\u0649 \u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u062C\u0645\u0627\u0639\u064A
    \u0648\u0627\u0644\u062A\u0648\u0642\u064A\u062A \u0648\u0627\u0644\u062A\u0648\u0627\u0635\u0644.
    \u062A\u0639\u0627\u0648\u0646\u0648\u0627 \u0644\u062D\u0644 \u0627\u0644\u0623\u0644\u063A\u0627\u0632\u060C
    \u0648\u062A\u062C\u0646\u0628\u0648\u0627 \u0627\u0644\u0627\u0643\u062A\u0634\u0627\u0641\u060C
    \u0648\u0627\u0635\u0646\u0639\u0648\u0627 \u0637\u0631\u064A\u0642\u064B\u0627
    \u0622\u0645\u0646\u064B\u0627 \u0644\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649
    \u0627\u0644\u062E\u0632\u0646\u0629.\r\n</color></align>\r\n\r\n<align=right><size=130%><b><color=#FFD54A>\u0627\u0644\u0647\u062F\u0641</color></b></size> 
    \r\n<color=#FDF67DFF>\u2022 \u0627\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649
    \u0627\u0644\u062E\u0632\u0646\u0629 \u062F\u0648\u0646 \u0623\u0646 \u064A\u062A\u0645
    \u0627\u0643\u062A\u0634\u0627\u0641\u0643  \r\n\u2022 \u062A\u0646\u0633\u064A\u0642
    \u0627\u0644\u062A\u062D\u0631\u0643\u0627\u062A \u0644\u0645\u0633\u0627\u0639\u062F\u0629
    \u0634\u0631\u064A\u0643\u0643 \u0639\u0644\u0649 \u0627\u0644\u062A\u0642\u062F\u0645 
    \r\n\u2022 \u0627\u0644\u062A\u0639\u0627\u0648\u0646 \u0644\u0625\u0646\u0647\u0627\u0621
    \u0643\u0644 \u0645\u0633\u062A\u0648\u0649 \u0628\u0646\u062C\u0627\u062D</color>\r\n\r\n<size=130%><b><color=#FFD54A>\u0645\u0627\u0630\u0627
    \u062A\u0641\u0639\u0644</color></b></size>  \r\n<color=#FDF67DFF>\u2022 \u062A\u0641\u0639\u064A\u0644
    \u0627\u0644\u0645\u0641\u0627\u062A\u064A\u062D \u0644\u0644\u062A\u062D\u0643\u0645
    \u0641\u064A \u0623\u062C\u0632\u0627\u0621 \u0645\u0646 \u0627\u0644\u0645\u0631\u062D\u0644\u0629 
    \r\n\u2022 \u062A\u0648\u0642\u064A\u062A \u0627\u0644\u0645\u0646\u0635\u0627\u062A
    \u0627\u0644\u0645\u062A\u062D\u0631\u0643\u0629 \u0644\u0644\u0648\u0635\u0648\u0644
    \u0625\u0644\u0649 \u0645\u0646\u0627\u0637\u0642 \u062C\u062F\u064A\u062F\u0629 
    \r\n\u2022 \u062F\u0641\u0639 \u0627\u0644\u0635\u0646\u0627\u062F\u064A\u0642
    \u0644\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649 \u0623\u0645\u0627\u0643\u0646
    \u0645\u0631\u062A\u0641\u0639\u0629 \u0623\u0648 \u0645\u0633\u0627\u0631\u0627\u062A
    \u0645\u063A\u0644\u0642\u0629  \r\n\u2022 \u062A\u062C\u0646\u0628 \u0643\u0627\u0645\u064A\u0631\u0627\u062A
    \u0627\u0644\u0645\u0631\u0627\u0642\u0628\u0629 \u0623\u0648 \u062A\u0639\u0637\u064A\u0644\u0647\u0627 
    \r\n\u2022 \u062A\u062C\u0627\u0648\u0632 \u0623\u0646\u0638\u0645\u0629 \u0627\u0644\u0644\u064A\u0632\u0631
    \u062F\u0648\u0646 \u062A\u0634\u063A\u064A\u0644 \u0627\u0644\u0625\u0646\u0630\u0627\u0631</color>\r\n\r\n<size=130%><b><color=#FFD54A>\u0627\u0644\u062A\u062D\u0643\u0645</color></b></size> 
    \r\n<color=#FDF67DFF>\u2022 \u0627\u0644\u0644\u0627\u0639\u0628 1: \u0627\u0644\u062A\u062D\u0631\u0643
    \u0628\u0627\u0633\u062A\u062E\u062F\u0627\u0645 <b>W A S D</b>  \r\n\u2022 \u0627\u0644\u0644\u0627\u0639\u0628
    2: \u0627\u0644\u062A\u062D\u0631\u0643 \u0628\u0627\u0633\u062A\u062E\u062F\u0627\u0645
    <b>Arrow Keys</b>  \r\n\u2022 \u0627\u0633\u062A\u062E\u062F\u0645 \u0632\u0631
    \u0627\u0644\u062A\u0641\u0627\u0639\u0644 \u0644\u062A\u0634\u063A\u064A\u0644
    \u0627\u0644\u0645\u0641\u0627\u062A\u064A\u062D \u0623\u0648 \u0627\u0644\u062A\u0641\u0627\u0639\u0644
    \u0645\u0639 \u0627\u0644\u0639\u0646\u0627\u0635\u0631  \r\n\u2022 \u062A\u0648\u0627\u0635\u0644
    \u0645\u0639 \u0634\u0631\u064A\u0643\u0643 \u0644\u062A\u0646\u0633\u064A\u0642
    \u0627\u0644\u062A\u0648\u0642\u064A\u062A \u0648\u0627\u0644\u062D\u0631\u0643\u0629</color>\r\n\r\n<size=130%><b><color=#FFD54A>\u0627\u0644\u0646\u0642\u0627\u0637
    \u0648\u0627\u0644\u062A\u0642\u062F\u0645</color></b></size>  \r\n<color=#FDF67DFF>\u2022
    \u0627\u0644\u0645\u0633\u062A\u0648\u064A\u0627\u062A \u0645\u062D\u062F\u062F\u0629
    \u0628\u0648\u0642\u062A \u2014 \u0643\u0644\u0645\u0627 \u0623\u0646\u0647\u064A\u062A
    \u0623\u0633\u0631\u0639 \u062D\u0635\u0644\u062A \u0639\u0644\u0649 \u0646\u0642\u0627\u0637
    \u0623\u0639\u0644\u0649  \r\n\u2022 \u0627\u062C\u0645\u0639 \u0627\u0644\u0639\u0646\u0627\u0635\u0631
    \u0627\u0644\u0627\u062E\u062A\u064A\u0627\u0631\u064A\u0629 \u0644\u0632\u064A\u0627\u062F\u0629
    \u0646\u062A\u064A\u062C\u062A\u0643  \r\n\u2022 \u064A\u0645\u0643\u0646\u0643
    \u0627\u0644\u062D\u0635\u0648\u0644 \u0639\u0644\u0649 \u0645\u0627 \u064A\u0635\u0644
    \u0625\u0644\u0649 <b>3 \u0646\u062C\u0648\u0645</b> \u0641\u064A \u0643\u0644
    \u0645\u0633\u062A\u0648\u0649  \r\n\u2022 \u0627\u062D\u0635\u0644 \u0639\u0644\u0649
    <b>\u0646\u062C\u0645\u062A\u064A\u0646</b> \u0639\u0644\u0649 \u0627\u0644\u0623\u0642\u0644
    \u0644\u0641\u062A\u062D \u0627\u0644\u0645\u0633\u062A\u0648\u0649 \u0627\u0644\u062A\u0627\u0644\u064A</color>\r\n\r\n<size=130%><b><color=#FFD54A>\u0625\u0630\u0627
    \u0639\u0644\u0642\u062A</color></b></size>  \r\n<color=#FDF67DFF>\u2022 \u0627\u0633\u062A\u062E\u062F\u0645
    <b>\u0646\u0638\u0627\u0645 \u0627\u0644\u062A\u0644\u0645\u064A\u062D\u0627\u062A</b>
    \u0644\u0644\u062D\u0635\u0648\u0644 \u0639\u0644\u0649 \u0627\u0644\u0645\u0633\u0627\u0639\u062F\u0629 
    \r\n\u2022 \u0627\u0644\u062A\u0644\u0645\u064A\u062D\u0627\u062A \u062A\u0631\u0634\u062F\u0643
    \u0625\u0644\u0649 \u0627\u0644\u062E\u0637\u0648\u0629 \u0627\u0644\u062A\u0627\u0644\u064A\u0629
    \u0641\u064A \u0627\u0644\u0644\u063A\u0632  \r\n\u2022 \u0631\u0627\u0642\u0628
    \u0627\u0644\u0634\u0627\u0634\u062A\u064A\u0646 \u0648\u062A\u0648\u0627\u0635\u0644
    \u0645\u0639 \u0634\u0631\u064A\u0643\u0643 \u0623\u0648\u0644\u064B\u0627  \r\n\u2022
    \u0627\u0633\u062A\u062E\u062F\u0645 \u0627\u0644\u062A\u0644\u0645\u064A\u062D\u0627\u062A
    \u0625\u0630\u0627 \u0644\u0645 \u062A\u0643\u0646 \u0645\u062A\u0623\u0643\u062F\u064B\u0627
    \u0645\u0645\u0627 \u064A\u062C\u0628 \u0641\u0639\u0644\u0647 \u0628\u0639\u062F
    \u0630\u0644\u0643</color>\r\n</align>"
  - "<align=center><color=#FDF67DFF>\r\nSplit Heist es un juego de plataformas y
    puzles cooperativo para dos jugadores ambientado en un banco de alta seguridad.
    Cada jugador explora \xE1reas separadas pero conectadas, por lo que el \xE9xito
    depende del trabajo en equipo, la sincronizaci\xF3n y la comunicaci\xF3n. Trabajad
    juntos para resolver puzles, evitar ser detectados y crear un camino seguro hacia
    la b\xF3veda.\r\n</color></align>\r\n\r\n<size=130%><b><color=#FFD54A>Objetivo</color></b></size> 
    \r\n<color=#FDF67DFF>\u2022 Llega a la b\xF3veda sin ser detectado  \r\n\u2022
    Coordina acciones para ayudar a tu compa\xF1ero a avanzar  \r\n\u2022 Trabajad
    juntos para completar cada nivel</color>\r\n\r\n<size=130%><b><color=#FFD54A>Qu\xE9
    hacer</color></b></size>  \r\n<color=#FDF67DFF>\u2022 Activa interruptores para
    controlar partes del nivel  \r\n\u2022 Sincroniza plataformas m\xF3viles para
    alcanzar nuevas zonas  \r\n\u2022 Empuja cajas para acceder a zonas elevadas
    o bloqueadas  \r\n\u2022 Evita o desactiva c\xE1maras de seguridad  \r\n\u2022
    Esquiva sistemas l\xE1ser sin activar alarmas</color>\r\n\r\n<size=130%><b><color=#FFD54A>Controles</color></b></size> 
    \r\n<color=#FDF67DFF>\u2022 Jugador 1: <b>W A S D</b>  \r\n\u2022 Jugador 2:
    <b>Flechas</b>  \r\n\u2022 Usa la tecla de interacci\xF3n para activar objetos 
    \r\n\u2022 Comun\xEDcate para coordinar movimientos y tiempo</color>\r\n\r\n<size=130%><b><color=#FFD54A>Puntuaci\xF3n
    y progreso</color></b></size>  \r\n<color=#FDF67DFF>\u2022 Los niveles son cronometrados
    \u2014 m\xE1s r\xE1pido = mejor puntuaci\xF3n  \r\n\u2022 Recoge objetos opcionales
    para mejorar tu puntuaci\xF3n  \r\n\u2022 Obt\xE9n hasta <b>3 estrellas</b> por
    nivel  \r\n\u2022 Consigue al menos <b>2 estrellas</b> para desbloquear el siguiente
    nivel</color>\r\n\r\n<size=130%><b><color=#FFD54A>Si te quedas atascado</color></b></size> 
    \r\n<color=#FDF67DFF>\u2022 Usa el <b>Sistema de pistas</b>  \r\n\u2022 Las pistas
    indican el siguiente paso del puzle  \r\n\u2022 Observa ambas pantallas y comun\xEDcate
    primero  \r\n\u2022 Usa pistas si no sabes qu\xE9 hacer</color>"
  - "<align=center><color=#FDF67DFF>\r\nSplit Heist est un jeu de plateforme et de
    r\xE9flexion coop\xE9ratif \xE0 deux joueurs se d\xE9roulant dans une banque
    hautement s\xE9curis\xE9e. Chaque joueur explore des zones s\xE9par\xE9es mais
    connect\xE9es, ce qui signifie que le succ\xE8s d\xE9pend du travail d\u2019\xE9quipe,
    du timing et de la communication. Travaillez ensemble pour r\xE9soudre des \xE9nigmes,
    \xE9viter la d\xE9tection et cr\xE9er un chemin s\xFBr vers le coffre.\r\n</color></align>\r\n\r\n<size=130%><b><color=#FFD54A>Objectif</color></b></size> 
    \r\n<color=#FDF67DFF>\u2022 Atteindre le coffre sans \xEAtre d\xE9tect\xE9  \r\n\u2022
    Coordonner vos actions pour aider votre partenaire  \r\n\u2022 Coop\xE9rer pour
    terminer chaque niveau</color>\r\n\r\n<size=130%><b><color=#FFD54A>Que faire</color></b></size> 
    \r\n<color=#FDF67DFF>\u2022 Activer des interrupteurs pour contr\xF4ler le niveau 
    \r\n\u2022 Synchroniser les plateformes mobiles  \r\n\u2022 D\xE9placer des caisses
    pour acc\xE9der \xE0 de nouvelles zones  \r\n\u2022 \xC9viter ou d\xE9sactiver
    les cam\xE9ras de s\xE9curit\xE9  \r\n\u2022 Traverser les lasers sans d\xE9clencher
    d\u2019alarme</color>\r\n\r\n<size=130%><b><color=#FFD54A>Contr\xF4les</color></b></size> 
    \r\n<color=#FDF67DFF>\u2022 Joueur 1 : <b>W A S D</b>  \r\n\u2022 Joueur 2 :
    <b>Fl\xE8ches</b>  \r\n\u2022 Utilisez la touche d\u2019interaction pour activer
    les objets  \r\n\u2022 Communiquez pour coordonner vos actions</color>\r\n\r\n<size=130%><b><color=#FFD54A>Score
    et progression</color></b></size>  \r\n<color=#FDF67DFF>\u2022 Les niveaux sont
    chronom\xE9tr\xE9s \u2014 plus rapide = meilleur score  \r\n\u2022 Collectez
    des objets optionnels pour am\xE9liorer votre score  \r\n\u2022 Gagnez jusqu\u2019\xE0
    <b>3 \xE9toiles</b> par niveau  \r\n\u2022 Obtenez au moins <b>2 \xE9toiles</b>
    pour d\xE9bloquer le suivant</color>\r\n\r\n<size=130%><b><color=#FFD54A>Si vous
    \xEAtes bloqu\xE9</color></b></size>  \r\n<color=#FDF67DFF>\u2022 Utilisez le
    <b>Syst\xE8me d\u2019indices</b>  \r\n\u2022 Les indices vous guident vers la
    prochaine \xE9tape  \r\n\u2022 Observez les deux \xE9crans et communiquez  \r\n\u2022
    Utilisez un indice si n\xE9cessaire</color>"
